################################################################################
# Docs
# - Ignore all markdown files, except:
#   - root README.md
#   - Extension/PRIVACY_POLICY.md
################################################################################
*.md
!/README.md
!/Extension/PRIVACY_POLICY.md

################################################################################
# OS junk / temp
################################################################################
.DS_Store
.AppleDouble
._*
Icon?
Thumbs.db

*.tmp
*.swp
*.swo
*.log

################################################################################
# IDE / editor
################################################################################
.vscode/
.idea/

################################################################################
# Node / package managers (if used)
################################################################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

################################################################################
# Secrets / local env
################################################################################
.env
.env.*

# Firebase config (contains API keys)
Extension/config/firebase-config.js

################################################################################
# Build artifacts
################################################################################
dist/
Extension/dist/
*.dmg
*.icns
*.rsrc
rw.*.dmg
TabDog_*.dmg

# DMG resources (generated)
scripts/dmg-resources/

################################################################################
# Xcode (if used)
################################################################################
xcuserdata/
*.xcuserstate
DerivedData/

################################################################################
# Browser extension packaging artifacts / keys
################################################################################
*.crx
*.pem
*.zip